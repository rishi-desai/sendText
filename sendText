def detect_order_type(xml_str):
    """Return (order_type, order_number, container_number)."""
    try:
        root = ET.fromstring(xml_str)
        if root.tag == "host2osr":
            children = list(root)
            child = children[0] if children else root
        else:
            child = root

        tag = child.tag
        order_number = child.get("order_number", "")
        container_number = child.get("container_number", "")

        if tag == "pick_order":
            return "pick", order_number, container_number

        if tag == "transport_order":
            cont_el = child.find(".//container")
            if cont_el is not None and not container_number:
                container_number = cont_el.get("container_number", "")
            if child.find(".//product") is not None:
                return "transport_gi", order_number, container_number
            return "transport", order_number, container_number

        if tag == "inventory_order":
            return "inventory", order_number, container_number

        if tag == "goods_in_order":
            # goods_add is a goods_in_order that contains a child element with text value "renewal"
            if any(el.text and el.text.strip().lower() == "renewal" for el in child.iter()):
                return "goods_add", order_number, container_number
            return "goods_in", order_number, container_number

        if tag == "dispatch_order":
            return "dispatch", order_number, container_number

        return "unknown", order_number, container_number
    except Exception:
        return "unknown", "", ""


def xml_summary(path):
    try:
        content = _read_file(path)
        order_type, order_number, container_number = detect_order_type(content)

        if order_type != "unknown":
            label, colour = _ORDER_TYPE_LABELS[order_type]
            label_str = _C._esc(colour, f"{label:<14}") if _C._on else f"{label:<14}"
            parts = []
            if order_number:
                parts.append(_C.dim("ord:") + " " + order_number)
            if container_number:
                parts.append(_C.dim("cont:") + " " + container_number)
            return label_str + "  " + "  ".join(parts)

        # Fallback: generic display
        root = ET.fromstring(content)
        tag = root.tag
        attrs = root.attrib
        attr_str = ""
        if attrs:
            k, v = next(iter(attrs.items()))
            short_v = v if len(v) <= 20 else v[:17] + "..."
            attr_str = f' {k}="{short_v}"'
            if len(attrs) > 1:
                attr_str += f" +{len(attrs) - 1}"
        children = list(root)
        n = len(children)
        child_str = (
            _C.dim(f"  [{n} child]" if n == 1 else f"  [{n} children]")
            if children else ""
        )
        return _C.yellow(f"<{tag}{attr_str}>") + child_str
    except Exception:
        return _C.dim("<invalid/unreadable>")


# ─────────────────────────────────────────────────────────────────────────────
# INCREMENT SUFFIX
# ─────────────────────────────────────────────────────────────────────────────

def increment_suffix(base, n=1):
    """Increment trailing numeric suffix of base by n, preserving zero-padding."""
    m = re.match(r'^(.*?)(\d+)$', str(base))
    if not m:
        return base
    prefix, digits = m.group(1), m.group(2)
    return prefix + str(int(digits) + n).zfill(len(digits))


def _suffix_number(base):
    m = re.match(r'^(.*?)(\d+)$', str(base))
    return int(m.group(2)) if m else None


# ─────────────────────────────────────────────────────────────────────────────
# QUEUE
# ─────────────────────────────────────────────────────────────────────────────

class QueueEntry:
    def __init__(self, template_path, xml_template, count, order_type, order_num_base, container_base):
        self.template_path  = template_path
        self.xml_template   = xml_template
        self.count          = count
        self.order_type     = order_type
        self.order_num_base = order_num_base
        self.container_base = container_base


def _expand_xml(xml_template, order_num_base, order_num_new, container_base, container_new):
    result = xml_template
    if order_num_base and order_num_new != order_num_base:
        result = result.replace(
            f'order_number="{order_num_base}"',
            f'order_number="{order_num_new}"', 1
        )
    if container_base and container_new != container_base:
        result = result.replace(
            f'container_number="{container_base}"',
            f'container_number="{container_new}"', 1
        )
    return result


def _expand_queue_entry(entry):
    """Return list of (order_num, container_num, xml) for this entry."""
    items = []
    for i in range(entry.count):
        on  = increment_suffix(entry.order_num_base, i)
        cn  = increment_suffix(entry.container_base, i)
        xml = _expand_xml(entry.xml_template, entry.order_num_base, on, entry.container_base, cn)
        items.append((on, cn, xml))
    return items


def _next_container_base(queue, prefix, types):
    """Find the starting container number that doesn't overlap with existing queue entries of the given types."""
    max_n = _suffix_number(prefix)
    if max_n is None:
        return prefix
    for entry in queue:
        if entry.order_type in types:
            last_n = _suffix_number(increment_suffix(entry.container_base, entry.count - 1))
            if last_n is not None and last_n >= max_n:
                max_n = last_n + 1
    m = re.match(r'^(.*?)(\d+)$', str(prefix))
    if m:
        return m.group(1) + str(max_n).zfill(len(m.group(2)))
    return prefix


def _add_to_queue(queue, path, content, count, telegrams_dir):
    order_type, order_num, container_num = detect_order_type(content)
    naming = load_container_naming(telegrams_dir)

    if order_type in ("transport_gi", "transport") and naming.get("source_prefix"):
        container_num = _next_container_base(queue, naming["source_prefix"], ("transport_gi", "transport"))
    elif order_type == "pick" and naming.get("target_prefix"):
        container_num = _next_container_base(queue, naming["target_prefix"], ("pick",))

    queue.append(QueueEntry(
        template_path=path,
        xml_template=content,
        count=count,
        order_type=order_type,
        order_num_base=order_num or "ORD-001",
        container_base=container_num or "TOTE001",
    ))


