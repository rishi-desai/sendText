# EDITOR HELPERS
# ─────────────────────────────────────────────────────────────────────────────

def _open_editor(editor, initial_content=""):
    """Open editor with initial_content in a temp file. Returns edited content or None."""
    fd, tmp_path = tempfile.mkstemp(prefix="sendText_", suffix=".xml")
    os.close(fd)
    try:
        with open(tmp_path, "w") as f:
            f.write(initial_content)
        ret = subprocess.call([editor, tmp_path])
        if ret != 0:
            print(_C.b_red(f"  Error: editor exited with code {ret}"))
            return None
        if not os.path.exists(tmp_path):
            print(_C.b_red("  Error: editor temp file not found"))
            return None
        content = _read_file(tmp_path)
        return content if content else None
    finally:
        try:
            os.remove(tmp_path)
        except OSError:
            pass


def _validate_xml(content):
    try:
        ET.fromstring(content)
        return True
    except ET.ParseError as e:
        print(_C.b_red(f"  Invalid XML — {e}"))
        return False


def create_new_telegram(editor, telegrams_dir):
    """Open editor for a brand-new telegram. Returns (path, content) or (None, None)."""
    print(_C.dim(f"  Opening {editor} — write your XML, save, and quit..."))
    content = _open_editor(editor, "")
    if not content:
        print(_C.dim("  Empty file — no telegram created."))
        return None, None
    if not _validate_xml(content):
        return None, None
    filename, _ = save_telegram_new(content, telegrams_dir)
    path = os.path.join(telegrams_dir, filename)
    return path, content


def edit_telegram_in_place(editor, source_path):
    """Open editor with existing file content. Overwrites the file on save. Returns new content or None."""
    initial = _read_file(source_path)
    print(_C.dim(f"  Editing: {os.path.basename(source_path)}"))
    print(_C.dim(f"  Opening {editor} — save and quit to continue..."))
    content = _open_editor(editor, initial)
    if content is None:
        return None
    if not _validate_xml(content):
        return None
    _overwrite_telegram(source_path, content)
    return content


def _edit_new_from_latest(editor, telegrams_dir):
    """Open editor with latest telegram as template. Returns content (does NOT save yet)."""
    latest = latest_telegram_path(telegrams_dir)
    if latest:
        print(_C.dim(f"  Template: telegrams/{os.path.basename(latest)}"))
        initial = _read_file(latest)
    else:
        print(_C.yellow("  No saved telegrams yet. Opening a blank editor file."))
        initial = ""
    print(_C.dim(f"  Opening {editor} — save and quit to continue..."))
    content = _open_editor(editor, initial)
    if content is None:
        sys.exit(1)
    return content


