    + _C.bold("m <n>")      + _C.dim(" rename   ")
    + _C.bold("dup <n>")    + _C.dim(" copy   ")
    + _C.b_grn("n")         + _C.dim(" new   ")
    + _C.bold("/<text>")    + _C.dim(" search   ")
    + _C.bold("r")          + _C.dim(" refresh   ")
    + _C.bold("Q")          + _C.dim(" queue   ")
    + _C.bold("sim")        + _C.dim(" simulator   ")
    + _C.bold("q")          + _C.dim(" quit")
)


def choose_saved_telegram(telegrams_dir, editor, queue, send_delay_ref, osrid):
    """Returns the path of the selected telegram for sending."""
    search_query = None
    all_saved = list_saved_telegrams(telegrams_dir)
    saved = _print_telegram_list(all_saved)
    if not saved:
        sys.exit(1)
    print(_PICKER_HELP)

    def _refresh_list():
        nonlocal all_saved, saved
        all_saved = list_saved_telegrams(telegrams_dir)
        if search_query:
            saved = _print_telegram_list(_filter_telegrams(all_saved, search_query), search_query)
        else:
            saved = _print_telegram_list(all_saved)

    while True:
        try:
            raw = input(_C.b_cyn("  > ") if _C._on else "  > ").strip()
        except (EOFError, KeyboardInterrupt):
            print("\n" + _C.dim("  Aborted."))
            sys.exit(0)

        if not raw:
            continue

        # ── Check for uppercase Q (queue) BEFORE lowercasing ────────────────
        if raw == "Q":
            queue_menu(telegrams_dir, osrid, editor, queue, send_delay_ref)
            _refresh_list()
            if not saved:
                sys.exit(1)
            print(_PICKER_HELP)
            continue

        low = raw.lower()

        if low in ("q", "quit", "exit"):
            print(_C.dim("  Aborted."))
            sys.exit(0)

        if low == "queue":
            queue_menu(telegrams_dir, osrid, editor, queue, send_delay_ref)
            _refresh_list()
            if not saved:
                sys.exit(1)
            print(_PICKER_HELP)
            continue

        if low in ("r", "refresh"):
            search_query = None
            _refresh_list()
            if not saved:
                sys.exit(1)
            print(_PICKER_HELP)
            continue

        if low in ("n", "new"):
            new_path, _ = create_new_telegram(editor, telegrams_dir)
            if new_path:
                print(_C.b_grn("  Created ") + _C.cyan(os.path.basename(new_path)))
            _refresh_list()
            if not saved:
                sys.exit(1)
            print(_PICKER_HELP)
            continue

        if low == "sim":
            sim_menu(telegrams_dir, osrid)
            _refresh_list()
            print(_PICKER_HELP)
            continue

        # ── Search filter ────────────────────────────────────────────────────
        if raw.startswith("/"):
            search_query = raw[1:].strip() or None
            _refresh_list()
            if saved:
                print(_PICKER_HELP)
            continue

        # ── Command + number(s) ──────────────────────────────────────────────
        cmd  = None
        rest = raw
        # Check "dup " before "d " to avoid prefix collision
        for prefix in ("dup ", "v ", "d ", "e ", "m "):
            if low.startswith(prefix):
                cmd  = prefix.strip()
                rest = raw[len(prefix):].strip()
                break

        # ── Multi-delete ─────────────────────────────────────────────────────
        if cmd == "d":
            tokens = rest.split()
            if not tokens:
                print(_C.yellow("  Usage: d <n> [n2 n3 ...] or d <n>-<m>"))
                continue
            idxs = _parse_indices(tokens, len(saved))
            if not idxs:
                print(_C.yellow("  No valid indices provided."))
                continue
            targets = [saved[i] for i in idxs]
            if len(targets) == 1:
                fname = os.path.basename(targets[0])
                prompt = _C.b_red(f"  Delete {fname}?") + _C.dim(" (y/n) ")
            else:
                print(_C.b_red(f"  Delete {len(targets)} telegrams:"))
                for t in targets:
                    print(_C.dim(f"    {os.path.basename(t)}"))
                prompt = _C.b_red("  Confirm delete all?") + _C.dim(" (y/n) ")
            try:
                ans = input(prompt).strip().lower()
            except (EOFError, KeyboardInterrupt):
                print()
                continue
            if ans in ("y", "yes"):
                for t in targets:
                    if delete_telegram(t):
                        print(_C.b_red("  Deleted ") + _C.dim(os.path.basename(t)))
                        queue[:] = [qe for qe in queue if qe.template_path != t]
            else:
                print(_C.dim("  Delete cancelled."))
            _refresh_list()
            if not saved:
                print(_C.dim("  No telegrams remaining."))
                sys.exit(0)
            print(_PICKER_HELP)
            continue

        try:
            index = int(rest)
        except ValueError:
            print(_C.yellow("  Unknown command.") + "  " + _PICKER_HELP.strip())
            continue

        if index < 1 or index > len(saved):
            print(_C.yellow(f"  Invalid selection. Choose 1 through {len(saved)}."))
            continue

        selected = saved[index - 1]
        filename = os.path.basename(selected)

        if cmd == "v":
            _print_xml_preview(_read_file(selected))
            continue

        if cmd == "e":
            new_content = edit_telegram_in_place(editor, selected)
            if new_content:
                print(_C.b_grn("  Updated ") + _C.cyan(f"telegrams/{filename}"))
                _refresh_list()
                print(_PICKER_HELP)
            continue

        if cmd == "m":
            try:
                new_name = input(_C.dim(f"  Rename '{filename}' to: ")).strip()
            except (EOFError, KeyboardInterrupt):
                print()
                continue
            if new_name:
                new_path = rename_telegram(selected, new_name, telegrams_dir)
                if new_path:
                    print(_C.b_grn("  Renamed \u2192 ") + _C.cyan(os.path.basename(new_path)))
                    _refresh_list()
                    print(_PICKER_HELP)
            continue

        if cmd == "dup":
            new_path = duplicate_telegram(selected, telegrams_dir)
            print(_C.b_grn("  Copied \u2192 ") + _C.cyan(os.path.basename(new_path)))
            _refresh_list()
            print(_PICKER_HELP)
            continue

        # No prefix — user picked this telegram to send
        return selected

# ─────────────────────────────────────────────────────────────────────────────
# SEND ONE  (used by --pick / --last / stdin / file modes)
# ─────────────────────────────────────────────────────────────────────────────

def _send_one(order, osrid, telegrams_dir, source_label, skip_confirm, no_sim):
    """Validate, save, preview, confirm, and send a single XML telegram.

    Handles sim insert automatically unless no_sim is True.
    """
    if not _validate_xml(order):
        sys.exit(1)

    saved, created = save_telegram_new(order, telegrams_dir)
    if created:
        print(_C.b_grn("  Saved ") + _C.cyan(f"telegrams/{saved}"))
    elif source_label:
        print(_C.dim(f"  Using {source_label}"))
    else:
        print(_C.dim(f"  Already saved as telegrams/{saved}"))

    _print_xml_preview(order)

    def _after_send():
        """Run post-send steps: print confirmation and optionally insert into sim."""
        print(_C.b_grn(f"  Sent to {osrid}.") + _C.dim(f"  telegrams/{saved}"))
        if not no_sim:
            cfg_sim = load_sim_config(telegrams_dir)
            order_type, _, container_num = detect_order_type(order)
            sim_state = {"source_idx": 0, "target_idx": 0}
            _do_sim_insert(cfg_sim, order_type, container_num, osrid, telegrams_dir, sim_state)

    if skip_confirm:
        ok = sendOrder(order, osrid)
        if not ok:
            sys.exit(1)
        _after_send()
        return

    try:
        confirm = input(
            _C.bold("  Send to ") + _C.b_cyn(osrid) + _C.bold("?") + _C.dim(" (y/n) ")
        )
    except (EOFError, KeyboardInterrupt):
        print()
        sys.exit(0)

    if confirm.strip().lower() in ("y", "yes"):
        ok = sendOrder(order, osrid)
        if not ok:
            sys.exit(1)
        _after_send()
    else:
        print(_C.dim(f"  Aborted. telegrams/{saved}"))


# ─────────────────────────────────────────────────────────────────────────────
# MAIN
# ─────────────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        prog="sendText",
        description="Send an XML telegram to the OSR."
    )
    parser.add_argument("--osr-id",    metavar="OSR_ID",
                        help="OSR target (e.g. osr1). Can also be set via $OSR_ID.")
    parser.add_argument("file",        nargs="?", metavar="FILE",
                        help="XML file or saved telegram name to send (resolves from telegrams/ by name).")
    parser.add_argument("--editor",    metavar="EDITOR",
                        help="Editor to use (overrides $EDITOR, default: vi).")
    parser.add_argument("--list-saved", action="store_true",
                        help="List saved telegrams from telegrams/ and exit.")
    parser.add_argument("--pick", "-p", action="store_true",
                        help="Pick a saved telegram from an interactive numbered menu (one-shot).")
    parser.add_argument("--last",      action="store_true",
                        help="Use the newest saved telegram from telegrams/.")
    parser.add_argument("--delete",    metavar="SAVED_XML",
                        help="Delete a specific saved telegram by filename or path and exit.")
    parser.add_argument("-y", "--yes", action="store_true",
                        help="Send without the final confirmation prompt.")
    parser.add_argument("--no-sim",    action="store_true",
                        help="Skip simulator insert even if sim is enabled.")
    args = parser.parse_args()

    osrid = args.osr_id or os.environ.get("OSR_ID", "")
    if not osrid and not args.list_saved and not args.delete:
        parser.error("osr-id must be specified via --osr-id or $OSR_ID")

    if osrid:
        src = "command line" if args.osr_id else "environment"
        print(_C.dim(f"  OSR target: ") + _C.b_cyn(osrid) + _C.dim(f"  ({src})"))

    script_dir    = os.path.dirname(os.path.abspath(__file__))
    telegrams_dir = os.path.join(script_dir, "telegrams")
    os.makedirs(telegrams_dir, exist_ok=True)

    # ── One-shot exit modes ──────────────────────────────────────────────────
    if args.list_saved:
        print_saved_telegrams(telegrams_dir)
        sys.exit(0)

    if args.delete:
        target   = resolve_saved_telegram(args.delete, telegrams_dir)
        filename = os.path.basename(target)
        try:
            answer = input(_C.b_red(f"  Delete telegrams/{filename}?") + _C.dim(" (y/n) ")).strip().lower()
        except (EOFError, KeyboardInterrupt):
            print()
            sys.exit(0)
        if answer in ("y", "yes"):
            if delete_telegram(target):
                print(_C.b_red("  Deleted ") + _C.dim(f"telegrams/{filename}"))
        else:
            print(_C.dim("  Delete cancelled."))
        sys.exit(0)

    editor = args.editor or os.environ.get("EDITOR", "notepad" if sys.platform == "win32" else "vi")
    queue          = []
    send_delay_ref = [2.0]

    # Start background sim container cache refresher if sim is enabled.
    # Runs immediately on startup and then every _SIM_CACHE_TTL/2 seconds so
    # sim_container_exists() always reads from a warm cache with no blocking.
    cfg_sim_init = load_sim_config(telegrams_dir)
    if cfg_sim_init.get("enabled") and not args.no_sim:
        _start_sim_cache_refresher(cfg_sim_init["sim_user"], f"sim{osrid}")

    # ── Non-interactive / one-shot send modes ────────────────────────────────
    if args.pick:
        selected = choose_saved_telegram(telegrams_dir, editor, queue, send_delay_ref, osrid)
        order    = _read_file(selected)
        _send_one(order, osrid, telegrams_dir,
                  f"telegrams/{os.path.basename(selected)}", args.yes, args.no_sim)
        sys.exit(0)

    if args.last:
        selected = latest_telegram_path(telegrams_dir)
        if not selected:
            print(_C.b_red("  Error: no saved telegrams found in telegrams/."))
            sys.exit(1)
        order = _read_file(selected)
        _send_one(order, osrid, telegrams_dir,
                  f"telegrams/{os.path.basename(selected)}", args.yes, args.no_sim)
        sys.exit(0)

    if not sys.stdin.isatty():
        order = sys.stdin.read().strip()
        print(_C.dim("  Reading XML from stdin..."))
        _send_one(order, osrid, telegrams_dir, None, args.yes, args.no_sim)
        sys.exit(0)

    if args.file:
        # Resolve bare name (e.g. "transport-flowrack.xml") from telegrams/ if not a direct path
        selected = resolve_saved_telegram(args.file, telegrams_dir)
        order    = _read_file(selected)
        label    = selected if os.path.dirname(selected) else f"telegrams/{os.path.basename(selected)}"
        _send_one(order, osrid, telegrams_dir, label, args.yes, args.no_sim)
        sys.exit(0)

    # ── Interactive loop ─────────────────────────────────────────────────────
    while True:
        if latest_telegram_path(telegrams_dir):
            selected = choose_saved_telegram(telegrams_dir, editor, queue, send_delay_ref, osrid)
            order    = _read_file(selected)
            label    = f"telegrams/{os.path.basename(selected)}"
        else:
            print(_C.dim("  No saved telegrams yet — opening editor for a new telegram."))
            order = _edit_new_from_latest(editor, telegrams_dir)
            label = None

        if not order:
            print(_C.b_red("  Error: no XML telegram provided."))
            continue

        if not _validate_xml(order):
            continue

        saved_fn, created = save_telegram_new(order, telegrams_dir)
        if created:
            print(_C.b_grn("  Saved ") + _C.cyan(f"telegrams/{saved_fn}"))
        elif label:
            print(_C.dim(f"  Using {label}"))
        else:
            print(_C.dim(f"  Already saved as telegrams/{saved_fn}"))

        _print_xml_preview(order)

        try:
            confirm = input(
                _C.bold("  Send to ") + _C.b_cyn(osrid) + _C.bold("?") + _C.dim(" (y/n) ")
            )
        except (EOFError, KeyboardInterrupt):
            print()
            sys.exit(0)

        if confirm.strip().lower() in ("y", "yes"):
            ok = sendOrder(order, osrid)
            if ok:
                print(_C.b_grn(f"  Sent to {osrid}.") + _C.dim(f"  telegrams/{saved_fn}"))
                # Sim insert
                if not args.no_sim:
                    cfg_sim = load_sim_config(telegrams_dir)
                    order_type, _, container_num = detect_order_type(order)
                    sim_state = {"source_idx": 0, "target_idx": 0}
                    _do_sim_insert(cfg_sim, order_type, container_num, osrid, telegrams_dir, sim_state)
            else:
                print(_C.b_red("  Send failed."))
        else:
            print(_C.dim(f"  Aborted. telegrams/{saved_fn}"))

        # Loop back to picker


if __name__ == "__main__":
    main()
