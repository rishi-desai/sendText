def sim_menu(telegrams_dir, osrid):
    while True:
        cfg = load_sim_config(telegrams_dir)
        src_elems = load_element_list(telegrams_dir, "sourceLoop.txt")
        tgt_elems = load_element_list(telegrams_dir, "targetLoop.txt")
        sim_osr   = f"sim{osrid}" if osrid else _C.dim("(not set)")
        enabled   = _C.b_grn("ENABLED") if cfg["enabled"] else _C.b_red("DISABLED")

        print()
        print(_C.bold("  Simulator Configuration"))
        print(_C.dim("  " + "─" * 78))
        print(f"  Status          : {enabled}")
        print(f"  Sim OSR         : {_C.cyan(sim_osr)}  {_C.dim('(derived from OSR_ID)')}")
        print(f"  Sim user        : {_C.cyan(cfg['sim_user'])}")
        print(f"  Default source  : {_C.cyan(cfg['default_source_element'] or '(none)')}")
        print(f"  Default target  : {_C.cyan(cfg['default_target_element'] or '(none)')}")
        print()
        print(f"  Source elements  {_C.dim('sourceLoop.txt')}  [{len(src_elems)} entry/entries]")
        for i, e in enumerate(src_elems, 1):
            print(f"    {_C.dim(str(i)+'.')} {e}")
        if not src_elems:
            print(_C.dim("    (empty)"))
        print(f"  Target elements  {_C.dim('targetLoop.txt')}  [{len(tgt_elems)} entry/entries]")
        for i, e in enumerate(tgt_elems, 1):
            print(f"    {_C.dim(str(i)+'.')} {e}")
        if not tgt_elems:
            print(_C.dim("    (empty)"))
        print(_C.dim("  " + "─" * 78))
        print(
            "  " + _C.bold("toggle") + _C.dim("  on/off   ")
            + _C.bold("user <name>") + _C.dim("  sim user   ")
            + _C.bold("src <elem>") + _C.dim("  default source   ")
            + _C.bold("tgt <elem>") + _C.dim("  default target")
        )
        print(
            "  " + _C.bold("addsrc <elem>") + _C.dim("  add sourceLoop   ")
            + _C.bold("addtgt <elem>") + _C.dim("  add targetLoop   ")
            + _C.b_red("delsrc <n>") + _C.dim("  remove source #n   ")
            + _C.b_red("deltgt <n>") + _C.dim("  remove target #n   ")
            + _C.bold("back") + _C.dim("  return")
        )
        print()

        try:
            raw = input(_C.b_cyn("  sim> ") if _C._on else "  sim> ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            break

        if not raw:
            continue

        parts = raw.split(None, 1)
        cmd = parts[0].lower()
        arg = parts[1].strip() if len(parts) > 1 else ""

        if cmd in ("back", "b", "q"):
            break
        elif cmd == "toggle":
            cfg["enabled"] = not cfg["enabled"]
            save_sim_config(telegrams_dir, cfg)
            print(f"  Sim insert {_C.b_grn('enabled') if cfg['enabled'] else _C.b_red('disabled')}.")
        elif cmd == "user":
            if arg:
                cfg["sim_user"] = arg
                save_sim_config(telegrams_dir, cfg)
                print(_C.b_grn("  Sim user updated."))
            else:
                print(_C.yellow("  Usage: user <name>"))
        elif cmd == "src":
            cfg["default_source_element"] = arg
            save_sim_config(telegrams_dir, cfg)
            print(_C.b_grn("  Default source element updated."))
        elif cmd == "tgt":
            cfg["default_target_element"] = arg
            save_sim_config(telegrams_dir, cfg)
            print(_C.b_grn("  Default target element updated."))
        elif cmd == "addsrc":
            if arg:
                src_elems.append(arg)
                save_element_list(telegrams_dir, "sourceLoop.txt", src_elems)
                print(_C.b_grn("  Added to sourceLoop."))
            else:
                print(_C.yellow("  Usage: addsrc <element>"))
        elif cmd == "addtgt":
            if arg:
                tgt_elems.append(arg)
                save_element_list(telegrams_dir, "targetLoop.txt", tgt_elems)
                print(_C.b_grn("  Added to targetLoop."))
            else:
                print(_C.yellow("  Usage: addtgt <element>"))
        elif cmd == "delsrc":
            try:
                i = int(arg) - 1
                if 0 <= i < len(src_elems):
                    removed = src_elems.pop(i)
                    save_element_list(telegrams_dir, "sourceLoop.txt", src_elems)
                    print(_C.b_red(f"  Removed: {removed}"))
                else:
                    print(_C.yellow("  Invalid index."))
            except ValueError:
                print(_C.yellow("  Usage: delsrc <n>"))
        elif cmd == "deltgt":
            try:
                i = int(arg) - 1
                if 0 <= i < len(tgt_elems):
                    removed = tgt_elems.pop(i)
                    save_element_list(telegrams_dir, "targetLoop.txt", tgt_elems)
                    print(_C.b_red(f"  Removed: {removed}"))
                else:
                    print(_C.yellow("  Invalid index."))
            except ValueError:
                print(_C.yellow("  Usage: deltgt <n>"))
        else:
            print(_C.yellow("  Unknown command."))


