_Q_SEP = _C.dim("  " + "─" * 102)


def _print_queue(queue, send_delay):
    total = sum(e.count for e in queue)
    print()
    print(
        _C.bold("  Queue")
        + _C.dim(f"  ({total} order{'s' if total != 1 else ''} total)")
        + "    "
        + _C.dim(f"[delay: {send_delay}s]")
    )
    print(_Q_SEP)
    if not queue:
        print(_C.dim("  (empty — use 'a <num> [count]' or 'n' to add)"))
    else:
        for qi, e in enumerate(queue, 1):
            label, colour = _ORDER_TYPE_LABELS.get(e.order_type, ("", "2"))
            label_str = _C._esc(colour, f"{label:<14}") if _C._on else f"{label:<14}"
            fname = _C.cyan(os.path.basename(e.template_path))
            if e.count > 1:
                last_on = increment_suffix(e.order_num_base, e.count - 1)
                last_cn = increment_suffix(e.container_base, e.count - 1)
                rng = (
                    _C.dim("ord:")  + f" {e.order_num_base}..{last_on}  "
                    + _C.dim("cont:") + f" {e.container_base}..{last_cn}"
                )
            else:
                rng = (
                    _C.dim("ord:")  + f" {e.order_num_base}  "
                    + _C.dim("cont:") + f" {e.container_base}"
                )
            qn = _C.b_yel(f"Q{qi:>2})")
            print(f"  {qn}  {label_str}  {_C.bold(f'x{e.count}'):>4}  {fname:<42}  {rng}")
    print(_Q_SEP)


