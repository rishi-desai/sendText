def queue_menu(telegrams_dir, osrid, editor, queue, send_delay_ref):
    sim_state = {"source_idx": 0, "target_idx": 0}
    search_query = None

    while True:
        all_saved = list_saved_telegrams(telegrams_dir)
        if search_query:
            saved = _print_telegram_list(_filter_telegrams(all_saved, search_query), search_query)
        else:
            saved = _print_telegram_list(all_saved)
        _print_queue(queue, send_delay_ref[0])
        print(_QUEUE_HELP_TGRAMS)
        print(_QUEUE_HELP_QUEUE)
        print(_QUEUE_HELP_ACTIONS)
        print()

        try:
            raw = input(_C.b_yel("  queue> ") if _C._on else "  queue> ").strip()
        except (EOFError, KeyboardInterrupt):
            print("\n" + _C.dim("  Returning to picker."))
            break

        if not raw:
            continue

        parts = raw.split()
        cmd = parts[0].lower()

        # ── Navigation ──────────────────────────────────────────────────────
        if cmd in ("back", "b"):
            break

        if cmd == "r":
            continue

        # ── New telegram ────────────────────────────────────────────────────
        if cmd == "n":
            new_path, content = create_new_telegram(editor, telegrams_dir)
            if new_path:
                print(_C.b_grn("  Created ") + _C.cyan(os.path.basename(new_path)))
                try:
                    ans = input(_C.dim("  Add to queue? Enter count (or Enter to skip): ")).strip()
                    if ans:
                        c = int(ans)
                        if c > 0:
                            _add_to_queue(queue, new_path, content, c, telegrams_dir)
                            print(_C.b_grn(f"  Added {c}× to queue."))
                except (ValueError, EOFError, KeyboardInterrupt):
                    pass
            continue

        # ── Preview telegram ────────────────────────────────────────────────
        if cmd == "v":
            if len(parts) < 2:
                print(_C.yellow("  Usage: v <n>"))
                continue
            try:
                i = int(parts[1]) - 1
                if 0 <= i < len(saved):
                    _print_xml_preview(_read_file(saved[i]))
                else:
                    print(_C.yellow("  Invalid selection."))
            except ValueError:
                print(_C.yellow("  Usage: v <n>"))
            continue

        # ── Edit telegram in-place ──────────────────────────────────────────
        if cmd == "e":
            if len(parts) < 2:
                print(_C.yellow("  Usage: e <n>"))
                continue
            try:
                i = int(parts[1]) - 1
                if 0 <= i < len(saved):
                    sel = saved[i]
                    new_content = edit_telegram_in_place(editor, sel)
                    if new_content:
                        print(_C.b_grn("  Updated ") + _C.cyan(os.path.basename(sel)))
                        # Sync any queue entries that use this file
                        for qe in queue:
                            if qe.template_path == sel:
                                qe.xml_template = new_content
                                qe.order_type, qe.order_num_base, qe.container_base = detect_order_type(new_content)
                else:
                    print(_C.yellow("  Invalid selection."))
            except ValueError:
                print(_C.yellow("  Usage: e <n>"))
            continue

        # ── Delete telegram(s) ──────────────────────────────────────────────
        if cmd == "d":
            if len(parts) < 2:
                print(_C.yellow("  Usage: d <n> [n2 n3 ...] or d <n>-<m>"))
                continue
            idxs = _parse_indices(parts[1:], len(saved))
            if not idxs:
                print(_C.yellow("  No valid indices provided."))
                continue
            targets = [saved[i] for i in idxs]
            if len(targets) == 1:
                fname = os.path.basename(targets[0])
                prompt = _C.b_red(f"  Delete {fname}?") + _C.dim(" (y/n) ")
            else:
                print(_C.b_red(f"  Delete {len(targets)} telegrams:"))
                for t in targets:
                    print(_C.dim(f"    {os.path.basename(t)}"))
                prompt = _C.b_red("  Confirm delete all?") + _C.dim(" (y/n) ")
            try:
                ans = input(prompt).strip().lower()
            except (EOFError, KeyboardInterrupt):
                print()
                continue
            if ans in ("y", "yes"):
                for t in targets:
                    if delete_telegram(t):
                        print(_C.b_red("  Deleted ") + _C.dim(os.path.basename(t)))
                        queue[:] = [qe for qe in queue if qe.template_path != t]
            else:
                print(_C.dim("  Delete cancelled."))
            continue

        # ── Duplicate telegram ──────────────────────────────────────────────
        if cmd == "dup":
            if len(parts) < 2:
                print(_C.yellow("  Usage: dup <n>"))
                continue
            try:
                i = int(parts[1]) - 1
                if 0 <= i < len(saved):
                    new_path = duplicate_telegram(saved[i], telegrams_dir)
                    print(_C.b_grn("  Copied \u2192 ") + _C.cyan(os.path.basename(new_path)))
                else:
                    print(_C.yellow("  Invalid selection."))
            except ValueError:
                print(_C.yellow("  Usage: dup <n>"))
            continue

        # ── Rename telegram ─────────────────────────────────────────────────
        if cmd == "m":
            if len(parts) < 2:
                print(_C.yellow("  Usage: m <n>"))
                continue
            try:
                i = int(parts[1]) - 1
                if 0 <= i < len(saved):
                    sel = saved[i]
                    fname = os.path.basename(sel)
                    try:
                        new_name = input(_C.dim(f"  Rename '{fname}' to: ")).strip()
                    except (EOFError, KeyboardInterrupt):
                        print()
                        continue
                    if new_name:
                        new_path = rename_telegram(sel, new_name, telegrams_dir)
                        if new_path:
                            print(_C.b_grn("  Renamed \u2192 ") + _C.cyan(os.path.basename(new_path)))
                            for qe in queue:
                                if qe.template_path == sel:
                                    qe.template_path = new_path
                else:
                    print(_C.yellow("  Invalid selection."))
            except ValueError:
                print(_C.yellow("  Usage: m <n>"))
            continue

        # ── Add to queue ────────────────────────────────────────────────────
        if cmd == "a":
            if len(parts) < 2:
                print(_C.yellow("  Usage: a <n> [count]"))
                continue
            try:
                i     = int(parts[1]) - 1
                count = int(parts[2]) if len(parts) >= 3 else 1
                if count < 1:
                    print(_C.yellow("  Count must be >= 1."))
                    continue
                if 0 <= i < len(saved):
                    content = _read_file(saved[i])
                    _add_to_queue(queue, saved[i], content, count, telegrams_dir)
                    total = sum(e.count for e in queue)
                    print(
                        _C.b_grn(f"  Added {count}\u00d7 ")
                        + _C.cyan(os.path.basename(saved[i]))
                        + _C.dim(f"  Queue total: {total}")
                    )
                else:
                    print(_C.yellow("  Invalid selection."))
            except ValueError:
                print(_C.yellow("  Usage: a <n> [count]"))
            continue

        # ── Remove from queue ───────────────────────────────────────────────
        if cmd == "dq":
            if len(parts) < 2:
                print(_C.yellow("  Usage: dq <n>"))
                continue
            try:
                qi = int(parts[1]) - 1
                if 0 <= qi < len(queue):
                    removed = queue.pop(qi)
                    print(_C.b_red(f"  Removed Q{qi+1}: ") + _C.dim(os.path.basename(removed.template_path)))
                else:
                    print(_C.yellow("  Invalid queue index."))
            except ValueError:
                print(_C.yellow("  Usage: dq <n>"))
            continue

        # ── Set queue entry count ───────────────────────────────────────────
        if cmd == "xq":
            if len(parts) < 3:
                print(_C.yellow("  Usage: xq <n> <count>"))
                continue
            try:
                qi    = int(parts[1]) - 1
                count = int(parts[2])
                if count < 1:
                    print(_C.yellow("  Count must be >= 1."))
                    continue
                if 0 <= qi < len(queue):
                    queue[qi].count = count
                    print(_C.b_grn(f"  Q{qi+1} count set to {count}."))
                else:
                    print(_C.yellow("  Invalid queue index."))
            except ValueError:
                print(_C.yellow("  Usage: xq <n> <count>"))
            continue

        # ── Preview queue entry (expanded) ──────────────────────────────────
        if cmd == "vq":
            if len(parts) < 2:
                print(_C.yellow("  Usage: vq <n>"))
                continue
            try:
                qi = int(parts[1]) - 1
                if 0 <= qi < len(queue):
                    entry = queue[qi]
                    items = _expand_queue_entry(entry)
                    print()
                    print(_C.bold(f"  Q{qi+1} preview") + _C.dim(f"  ({entry.count} order{'s' if entry.count != 1 else ''})"))
                    print(_C.dim("  " + "─" * 78))
                    for on, cn, _ in items:
                        print(f"  {_C.dim('ord:')} {on}   {_C.dim('cont:')} {cn}")
                    print(_C.dim("  ─── First order XML ───"))
                    if items:
                        _print_xml_preview(items[0][2])
                    print(_C.dim("  " + "─" * 78))
                    print()
                else:
                    print(_C.yellow("  Invalid queue index."))
            except ValueError:
                print(_C.yellow("  Usage: vq <n>"))
            continue

        # ── Set delay ───────────────────────────────────────────────────────
        if cmd == "delay":
            if len(parts) < 2:
                print(_C.yellow(f"  Current delay: {send_delay_ref[0]}s.  Usage: delay <seconds>"))
                continue
            try:
                send_delay_ref[0] = float(parts[1])
                print(_C.b_grn(f"  Delay set to {send_delay_ref[0]}s."))
            except ValueError:
                print(_C.yellow("  Usage: delay <seconds>"))
            continue

        # ── Send queue ──────────────────────────────────────────────────────
        if cmd in ("send", "s"):
            if not queue:
                print(_C.yellow("  Queue is empty."))
                continue
            total = sum(e.count for e in queue)
            try:
                confirm = input(
                    _C.bold(f"  Send {total} order(s) to OSR '")
                    + _C.b_cyn(osrid) + _C.bold("'?") + _C.dim(" (y/n) ")
                ).strip().lower()
            except (EOFError, KeyboardInterrupt):
                print()
                continue
            if confirm not in ("y", "yes"):
                print(_C.dim("  Aborted."))
                continue

            cfg_sim = load_sim_config(telegrams_dir)
            sent = 0
            errors = 0
            seq = 0

            for entry in queue:
                items = _expand_queue_entry(entry)
                for on, cn, xml in items:
                    seq += 1
                    print(_C.dim(f"\n  [{seq}/{total}] Sending {on}  (cont: {cn})..."))
                    ok = sendOrder(xml, osrid)
                    if ok:
                        sent += 1
                        print(_C.b_grn("  Sent."))
                    else:
                        errors += 1

                    # Sim insert
                    if ok:
                        _do_sim_insert(cfg_sim, entry.order_type, cn, osrid, telegrams_dir, sim_state)

                    if seq < total and send_delay_ref[0] > 0:
                        time.sleep(send_delay_ref[0])

            print()
            suffix = f", {errors} failed." if errors else "."
            print(_C.b_grn(f"  Done. {sent} order(s) sent") + suffix)

            # Advance bases for next send
            for entry in queue:
                entry.order_num_base = increment_suffix(entry.order_num_base, entry.count)
                entry.container_base  = increment_suffix(entry.container_base, entry.count)
            continue

        # ── Clear queue ──────────────────────────────────────────────────────
        if cmd in ("clear", "c"):
            if queue:
                try:
                    ans = input(_C.b_red("  Clear queue?") + _C.dim(" (y/n) ")).strip().lower()
                except (EOFError, KeyboardInterrupt):
                    print()
                    continue
                if ans in ("y", "yes"):
                    queue.clear()
                    print(_C.dim("  Queue cleared."))
            else:
                print(_C.dim("  Queue is already empty."))
            continue

        # ── Container naming config ─────────────────────────────────────────
        if cmd == "cfg":
            _cfg_naming_menu(telegrams_dir)
            continue

        # ── Sim config ──────────────────────────────────────────────────────
        if cmd == "sim":
            sim_menu(telegrams_dir, osrid)
            continue

        print(_C.yellow("  Unknown command."))


