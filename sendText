def _read_file(path):
    with open(path, "r") as f:
        return f.read().strip()


def list_saved_telegrams(telegrams_dir):
    if not os.path.isdir(telegrams_dir):
        return []
    xml_files = [
        os.path.join(telegrams_dir, f)
        for f in os.listdir(telegrams_dir)
        if f.endswith(".xml") and not f.startswith(".")
    ]
    return sorted(xml_files, key=os.path.getmtime, reverse=True)


def latest_telegram_path(telegrams_dir):
    saved = list_saved_telegrams(telegrams_dir)
    return saved[0] if saved else None


_SEP = _C.dim("  " + "─" * 102)


def _filter_telegrams(saved, query):
    """Return paths whose filename or summary contains query (case-insensitive)."""
    q = query.lower()
    result = []
    for path in saved:
        if q in os.path.basename(path).lower():
            result.append(path)
        else:
            try:
                if q in xml_summary(path).lower():
                    result.append(path)
            except Exception:
                pass
    return result


def _parse_indices(tokens, max_n):
    """Parse tokens like ['1', '2-4', '3'] into a sorted list of 0-based indices."""
    indices = set()
    for tok in tokens:
        for part in tok.split(","):
            part = part.strip()
            if not part:
                continue
            if "-" in part:
                lo_s, _, hi_s = part.partition("-")
                try:
                    lo, hi = int(lo_s), int(hi_s)
                    for i in range(lo, hi + 1):
                        if 1 <= i <= max_n:
                            indices.add(i - 1)
                except ValueError:
                    pass
            else:
                try:
                    i = int(part)
                    if 1 <= i <= max_n:
                        indices.add(i - 1)
                except ValueError:
                    pass
    return sorted(indices)


def _print_telegram_list(paths, search_query=None):
    """Print a (possibly filtered) list of telegram paths. Returns paths."""
    if not paths:
        if search_query:
            print(_C.yellow(f"  No telegrams matching '{search_query}'."))
        else:
            print(_C.yellow("  No saved telegrams found in telegrams/."))
        return paths
    header = _C.bold("  Saved telegrams") + _C.dim("  (newest first)")
    if search_query:
        n = len(paths)
        header += "   " + _C.yellow(f"/{search_query}") + _C.dim(f"  ({n} match{'es' if n != 1 else ''})")
    print()
    print(header)
    print(_SEP)
    for idx, path in enumerate(paths, start=1):
        filename  = os.path.basename(path)
        modified  = datetime.fromtimestamp(os.path.getmtime(path)).strftime("%Y-%m-%d %H:%M:%S")
        size      = _fmt_size(os.path.getsize(path))
        summary   = xml_summary(path)
        num       = _C.b_cyn(f"{idx:>3})")
        fname     = _C.cyan(f"{filename:<42}")
        ts        = _C.dim(modified)
        sz        = _C.dim(f"{size:>7}")
        print(f"  {num}  {fname}  {ts}  {sz}   {summary}")
    print(_SEP)
    return paths


def print_saved_telegrams(telegrams_dir):
    saved = list_saved_telegrams(telegrams_dir)
    return _print_telegram_list(saved)


def save_telegram_new(order, telegrams_dir):
    """Save as a new timestamped file. Skips creation if identical XML already exists."""
    os.makedirs(telegrams_dir, exist_ok=True)
    normalized = order.strip()
    for filename in sorted(f for f in os.listdir(telegrams_dir) if f.endswith(".xml") and not f.startswith(".")):
        path = os.path.join(telegrams_dir, filename)
        try:
            if _read_file(path) == normalized:
                return filename, False
        except OSError:
            continue
    filename = datetime.now().strftime("telegram_%Y%m%d_%H%M%S_%f.xml")
    path = os.path.join(telegrams_dir, filename)
    with open(path, "w") as f:
        f.write(normalized + "\n")
    return filename, True


def _overwrite_telegram(path, content):
    with open(path, "w") as f:
        f.write(content.strip() + "\n")


def rename_telegram(old_path, new_name, telegrams_dir):
    new_name = new_name.strip()
    if new_name.lower().endswith(".xml"):
        new_name = new_name[:-4]
    if not new_name:
        return None
    new_path = os.path.join(telegrams_dir, new_name + ".xml")
    if os.path.exists(new_path):
        print(_C.b_red(f"  Error: {new_name}.xml already exists."))
        return None
    try:
        os.rename(old_path, new_path)
        return new_path
    except OSError as e:
        print(_C.b_red(f"  Error renaming: {e}"))
        return None


def duplicate_telegram(source_path, telegrams_dir):
    content = _read_file(source_path)
    filename = datetime.now().strftime("telegram_%Y%m%d_%H%M%S_%f.xml")
    new_path = os.path.join(telegrams_dir, filename)
    with open(new_path, "w") as f:
        f.write(content + "\n")
    return new_path


def delete_telegram(path):
    try:
        os.remove(path)
        return True
    except OSError as e:
        print(_C.b_red(f"  Error deleting {os.path.basename(path)}: {e}"))
        return False


def resolve_saved_telegram(saved_arg, telegrams_dir):
    candidates = [saved_arg, os.path.join(telegrams_dir, saved_arg)]
    if not saved_arg.endswith(".xml"):
        candidates += [saved_arg + ".xml", os.path.join(telegrams_dir, saved_arg + ".xml")]
    for c in candidates:
        if os.path.exists(c):
            return c
    print(_C.b_red(f"  Error: saved telegram not found: {saved_arg}"))
    print(_C.dim("  Tip: use --list-saved or --pick to see available telegrams."))
    sys.exit(1)


