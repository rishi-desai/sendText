def run_sim(sim_user, sim_osr, element_filter, container):
    cmd = (
        f"sudo su - {sim_user} -c "
        f"'simulator --config {sim_osr}.properties -i {element_filter} {container}'"
    )
    print(_C.dim(f"  sim: {cmd}"))
    result = subprocess.run(cmd, shell=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, universal_newlines=True)
    if result.returncode != 0:
        output = (result.stdout + result.stderr).strip()
        print(_C.yellow(f"  Warning: sim insert exited {result.returncode}: {output}"))
        return False
    return True


# ── Simulator container cache ────────────────────────────────────────────────
# Container lists are fetched in a background thread so sends don't block.
# Cache is keyed by sim_osr and expires after _SIM_CACHE_TTL seconds.

_SIM_CACHE_TTL  = 60  # seconds before a cached container list is considered stale
_sim_cache      = {}  # {sim_osr: {"output": str, "fetched_at": float}}
_sim_cache_lock = threading.Lock()


def _fetch_sim_containers(sim_user, sim_osr):
    """Fetch the full container list from the simulator and store it in the cache.

    Intended to be called from a daemon thread via prefetch_sim_cache().
    Uses the simulator binary directly (same as run_sim) so it works in the
    non-interactive sudo su shell where wrapper scripts are not on PATH.
    """
    cmd = (
        f"sudo su - {sim_user} -c "
        f"'simulator --config {sim_osr}.properties -c'"
    )
    result = subprocess.run(cmd, shell=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, universal_newlines=True)
    output = result.stdout + result.stderr
    with _sim_cache_lock:
        _sim_cache[sim_osr] = {"output": output, "fetched_at": time.monotonic()}


def _start_sim_cache_refresher(sim_user, sim_osr):
    """Start a single daemon thread that keeps the container cache continuously warm.

    The thread runs for the lifetime of the process, refreshing the cache every
    _SIM_CACHE_TTL / 2 seconds so it is always near-fresh when sim_container_exists()
    is called.  Safe to call multiple times — only one thread is ever started.
    """
    if getattr(_start_sim_cache_refresher, "_started", False):
        return
    _start_sim_cache_refresher._started = True

    def _loop():
        while True:
            _fetch_sim_containers(sim_user, sim_osr)
            time.sleep(_SIM_CACHE_TTL / 2)

    t = threading.Thread(target=_loop, daemon=True)
    t.start()


def sim_container_exists(sim_user, sim_osr, container):
    """Return True if container is already registered in the simulator.

    Uses the in-memory cache populated by prefetch_sim_cache() / _fetch_sim_containers().
    If the cache is stale or missing, fetches inline (blocking) as a fallback.
    """
    with _sim_cache_lock:
        entry = _sim_cache.get(sim_osr)
        if entry and (time.monotonic() - entry["fetched_at"]) < _SIM_CACHE_TTL:
            return container.lower() in entry["output"].lower()

    # Cache miss or expired — fetch inline so we always get a correct answer.
    print(_C.dim("  Sim: refreshing container list..."))
    _fetch_sim_containers(sim_user, sim_osr)
    with _sim_cache_lock:
        entry = _sim_cache.get(sim_osr)
    return bool(entry) and container.lower() in entry["output"].lower()


def _do_sim_insert(cfg_sim, order_type, container_num, osrid, telegrams_dir, sim_state):
    """Perform a simulator insert after sending an order.

    Only runs for order types listed in _SIM_INSERT_TYPES.  Always checks
    whether the container is already present in the simulator before inserting
    to avoid duplicates.

    To enable sim inserts for a new order type, add it to _SIM_INSERT_TYPES.
    To change which element list a new type uses, update pick_sim_element.
    """
    if not cfg_sim.get("enabled"):
        return
    if order_type not in _SIM_INSERT_TYPES:
        return

    sim_osr = f"sim{osrid}"

    if order_type not in _ALWAYS_SIM_INSERT:
        if sim_container_exists(cfg_sim["sim_user"], sim_osr, container_num):
            print(_C.dim(f"  Sim: {container_num} already present — skipping insert."))
            return

    element = pick_sim_element(telegrams_dir, order_type, sim_state)
    if element:
        run_sim(cfg_sim["sim_user"], sim_osr, element, container_num)
    else:
        print(_C.yellow("  Sim enabled but no element configured — skipping."))


def pick_sim_element(telegrams_dir, order_type, sim_state):
    """Round-robin element selection. sim_state is a mutable dict with index counters."""
    cfg = load_sim_config(telegrams_dir)
    if order_type in ("transport_gi", "transport"):
        elements = load_element_list(telegrams_dir, "sourceLoop.txt")
        if elements:
            idx = sim_state.get("source_idx", 0) % len(elements)
            sim_state["source_idx"] = idx + 1
            return elements[idx]
        return cfg.get("default_source_element") or None
    elif order_type == "pick":
        elements = load_element_list(telegrams_dir, "targetLoop.txt")
        if elements:
            idx = sim_state.get("target_idx", 0) % len(elements)
            sim_state["target_idx"] = idx + 1
            return elements[idx]
        return cfg.get("default_target_element") or None
    return None


