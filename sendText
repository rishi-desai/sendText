def sendOrder(order, osrid):
    """Returns True on success, False on failure (does NOT call sys.exit)."""
    orb = CORBA.ORB_init([], CORBA.ORB_ID)
    orb.resolve_initial_references("RootPOA")
    obj = orb.resolve_initial_references("NameService")
    rootContext = obj._narrow(CosNaming.NamingContext)
    try:
        name = [
            CosNaming.NameComponent(osrid, ""),
            CosNaming.NameComponent("ServicePorts", ""),
            CosNaming.NameComponent("Hio", ""),
        ]
        sobj = rootContext.resolve(name)
        servant = sobj._narrow(OSR.Hio.ServicePort)
        servant.sendOrder(order)
        return True
    except Exception as e:
        print(_C.b_red(f"  Unable to send order: {e}"))
        return False


